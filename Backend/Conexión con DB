//DB config

const express = require('express');
const { Pool } = require('pg');
const cors = require('cors');

const app = express();
const PORT = 5000;
app.use(cors());
app.use(express.json());

const pool = new Pool({
    user: 'postgres',
    host: 'localhost',        
    database: 'TriDa',   
    password: 'Trida.db',  
    port: 5432,                 
});

pool.connect((err) => {
    if (err) {
        console.error('Error conectando a la base de datos:', err.stack);
    } else {
        console.log('¡Conectado exitosamente a PostgreSQL!');
    }
});

// Mostrar que esta conectado
const comprobarYMostrarClientes = async () => {
    try {
        // Usamos 'trida.tablas' para realizar consultas (trida. es un esquema).
        const resultadoClientes = await pool.query('SELECT * FROM trida.clientes ORDER BY id_cliente ASC;');
        
        console.log('\n-------------------------------------------');
        console.log('Backend tabla clientes:');
        console.table(resultadoClientes.rows);
        console.log('-------------------------------------------\n');

    } catch (error) {
        console.error(' Error al intentar consultar tus clientes reales:', error);
        console.log('Si da un error de base de datos, revisar si el nombre en el pool es diferente');
    }
};

// Se ejecuta al arrancar
comprobarYMostrarClientes();

//worker para consultar tareas

const consultarTareasWorker = async () => {
    try {
        const resultado = await pool.query('SELECT * FROM clientes;');
        
        // Aquí podrías procesar la info si quisieras, por ahora solo retornamos las filas
        return resultado.rows; 
    } catch (error) {
        console.error("Error en el worker de la DB:", error);
        throw error;
    }
};

//  API 
 
app.get('/api/tareas', async (req, res) => {
    try {
        
        const datosTares = await consultarTareasWorker();

        res.json(datosTares);
    } catch (error) {
        res.status(500).json({ error: 'Hubo un problema al obtener las tareas' });
    }
});

